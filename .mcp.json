{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@context7/mcp"]
    },
    "pulumi": {
      "type": "http",
      "url": "https://mcp.ai.pulumi.com/mcp"
    },
    "pulumi-events": {
      "type": "http",
      "url": "http://localhost:8080/mcp"
    },
    "yaah": {
      "type": "stdio",
      "command": "yaah",
      "args": ["serve"]
    }
  }
}
