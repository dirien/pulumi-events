{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@context7/mcp"]
    },
    "pulumi": {
      "type": "http",
      "url": "https://mcp.ai.pulumi.com/mcp"
    },
    "pulumi-events": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://d3hhsm0lhey01y.cloudfront.net/mcp"
      ]
    },
    "yaah": {
      "type": "stdio",
      "command": "yaah",
      "args": ["serve"]
    }
  }
}
